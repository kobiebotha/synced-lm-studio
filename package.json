{
  "name": "synced-lm-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node src/server.mjs",
    "check": "node --check src/server.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "generate:conversation": "node scripts/generate-conversation.mjs",
    "infra:supabase:start": "supabase start",
    "infra:supabase:status": "supabase status -o env",
    "infra:powersync:start": "pnpm exec powersync docker start",
    "infra:powersync:status": "API_URL=http://127.0.0.1:8080 PS_ADMIN_TOKEN=dev-token-do-not-use-in-production pnpm exec powersync status",
    "bootstrap:local-env": "node scripts/write-local-env.mjs",
    "bootstrap:dev-user": "node scripts/bootstrap-dev-user.mjs",
    "dev:bridge": "pnpm --filter @synced-lm-studio/bridge start",
    "dev:bridge:watch": "pnpm --filter @synced-lm-studio/bridge dev",
    "dev:web": "pnpm --filter @synced-lm-studio/web dev",
    "check:shared": "pnpm --filter @synced-lm-studio/shared check",
    "check:bridge": "pnpm --filter @synced-lm-studio/bridge check",
    "check:web": "pnpm --filter @synced-lm-studio/web check",
    "check:workspace": "pnpm check:shared && pnpm check:bridge && pnpm check:web"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "powersync": "0.9.2",
    "typescript": "^5.9.3"
  }
}
